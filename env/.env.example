# Coffee Cart Application URLs
APP_URL=http://localhost:5273
API_URL=http://localhost:3002

# Authentication Credentials (admin)
APP_EMAIL=admin@example.com
APP_PASSWORD=admin

# Authentication Credentials (standard user)
USER_EMAIL=user@example.com
USER_PASSWORD=password

# Path to coffee-cart project (for webServer)
COFFEE_CART_PATH=d:/gitrepos/coffee-cart

# pw-api-plugin: API call logging in Playwright UI / Trace Viewer
# Set to "true" to see request/response cards (requires browser context)
# Default: off — no browser overhead for API-only tests
LOG_API_UI=false
