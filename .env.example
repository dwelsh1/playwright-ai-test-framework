# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# These defaults match the coffee-cart demo app and work without any changes locally.

# ── Application URLs ──────────────────────────────────────────────────────────
APP_URL=http://localhost:5273
API_URL=http://localhost:3002

# ── Test credentials ──────────────────────────────────────────────────────────
# Omit these to use the coffee-cart demo defaults (user@example.com / password).
# Set them in CI secrets for real applications.
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=password
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=admin

# ── Environment ───────────────────────────────────────────────────────────────
# Options: dev | staging | production  (default: dev)
TEST_ENV=dev

# ── Sauce Demo ────────────────────────────────────────────────────────────
# Omit these to use the publicly documented demo defaults (standard_user / secret_sauce).
# Set them in CI secrets to override with specific test accounts.
SAUCE_DEMO_URL=https://www.saucedemo.com
SAUCE_DEMO_USERNAME=standard_user
SAUCE_DEMO_PASSWORD=secret_sauce

# ── Optional ──────────────────────────────────────────────────────────────────
# pw-api-plugin (https://github.com/sclavijosuero/pw-api-plugin) — used by the `api` fixture.
# LOG_API_UI: request/response cards in Playwright UI + Trace Viewer (default on unless "false").
#   Framework default below is false-equivalent for speed in API-only runs; set LOG_API_UI=true to debug.
LOG_API_UI=false
# LOG_API_REPORT: attach API request/response details to the HTML report (default off upstream; set true for CI artifacts).
# LOG_API_REPORT=false
# COLOR_SCHEME: light | dark | accessible — theme for pw-api-plugin cards (UI, trace, HTML).
# COLOR_SCHEME=light

# Page objects / helpers: debug|info|warn|error (default warn — keeps Smart Reporter runs quiet)
# LOG_LEVEL=debug
